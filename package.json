{
  "name": "bad-day-receipt",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit -p tsconfig.app.json && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.api.json",
    "test:carry-forward": "vitest run src/carry-forward api/compile-task.test.ts",
    "release:carry-forward": "npm run typecheck && npm run test:carry-forward && npm run build && playwright test tests/e2e/carry-forward.spec.ts tests/e2e/carry-forward-accessibility.spec.ts tests/e2e/carry-forward-viewports.spec.ts --project=chromium-desktop",
    "analyze": "npm run build && node scripts/analyze-build.mjs",
    "test:e2e": "playwright test tests/e2e --grep-invert \"@accessibility|@viewport\"",
    "test:accessibility": "playwright test tests/e2e/accessibility-gate.spec.ts",
    "test:viewports": "playwright test tests/e2e/viewport-matrix.spec.ts --project=chromium-mobile --project=webkit-mobile",
    "test:visual": "playwright test tests/visual",
    "test:visual:release": "playwright test tests/visual/mobile-instrument-release.spec.ts --project=chromium-mobile --project=chromium-desktop"
  },
  "dependencies": {
    "@vercel/analytics": "2.0.1",
    "openai": "^6.48.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.10.2",
    "@playwright/test": "1.55.0",
    "@types/node": "^26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "typescript": "7.0.2",
    "vite": "8.1.4",
    "vitest": "4.1.10"
  }
}
