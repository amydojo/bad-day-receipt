{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npx playwright install chromium webkit && VITE_THREE_ENDINGS=true npx playwright test tests/e2e/three-endings-foundation.spec.ts && npm run build",
  "functions": {
    "api/compile-task.ts": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/access/:path*", "destination": "/index.html" },
    { "source": "/field/:path*", "destination": "/index.html" },
    { "source": "/go/:path*", "destination": "/index.html" },
    { "source": "/lab/:path*", "destination": "/index.html" },
    { "source": "/carry-forward", "destination": "/index.html" }
  ]
}
